# HTTP + socket.io
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Abstract chain wiring (Sepolia testnet defaults)
CHAIN_ID=11124
LOBBY_ADDRESS=0x0000000000000000000000000000000000000000
BOT_MATCH_ADDRESS=0x0000000000000000000000000000000000000000

# ECDSA key that signs match results. MUST match `serverSigner` in the deployed
# contracts. Generate a throwaway one for local development with:
#   node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
# Never reuse a production key here; production keys should be held in a secret
# manager (KMS / Vault / 1Password) and injected at runtime.
SERVER_SIGNER_KEY=0x

# Sentry (error tracking). DSN is public by design.
# Leave empty to disable Sentry entirely.
SENTRY_DSN=
RELEASE_TAG=

# Supabase (Postgres). DATABASE_URL is the session-pooler URL from
# Supabase project settings → Database → Connection string → "Session pooler".
# Required for Phase 8 (server-authoritative state); leave empty during early
# bring-up — DB-backed routes will refuse to start until it's set.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
