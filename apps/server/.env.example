# HTTP + socket.io
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Abstract chain wiring (Sepolia testnet defaults)
CHAIN_ID=11124
LOBBY_ADDRESS=0x0000000000000000000000000000000000000000
BOT_MATCH_ADDRESS=0x0000000000000000000000000000000000000000

# ECDSA key that signs match results. MUST match `serverSigner` in the deployed
# contracts. Generate a throwaway one for local development with:
#   node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
# Never reuse a production key here; production keys should be held in a secret
# manager (KMS / Vault / 1Password) and injected at runtime.
SERVER_SIGNER_KEY=0x

# Sentry (error tracking). DSN is public by design.
# Leave empty to disable Sentry entirely.
SENTRY_DSN=
RELEASE_TAG=

# Supabase (Postgres). DATABASE_URL is the session-pooler URL from
# Supabase project settings → Database → Connection string → "Session pooler".
# Required for Phase 8 (server-authoritative state); leave empty during early
# bring-up — DB-backed routes will refuse to start until it's set.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# SIWE (Sign-In With Ethereum) auth. All three are required to enable
# /auth/nonce and /auth/verify; leave any blank during early bring-up
# and the routes will return 503.
#   - JWT_SECRET: random 32+ char string. Generate with:
#       node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#   - AUTH_DOMAIN: the exact `domain` clients put in their SIWE message,
#     usually your hostname (e.g. seabattle.xyz, or localhost:5173 for dev).
#   - AUTH_RPC_URL: chain RPC for EIP-1271 contract-wallet verification
#     (AGW is a smart account, this is mandatory). Use the same RPC the
#     contracts deploy to. e.g. https://api.testnet.abs.xyz
#   - AUTH_CHAIN_ID: defaults to CHAIN_ID above when unset.
JWT_SECRET=
# JWT_SECRET_PREVIOUS (optional): comma-separated list of previously-active
# JWT secrets. The server still ACCEPTS tokens signed with any of these (so
# users don't get bumped out the moment you rotate), but only ever ISSUES
# new tokens with JWT_SECRET. Leave blank in steady state. Rotation drill:
#   1. Generate NEW secret. Set JWT_SECRET=NEW, JWT_SECRET_PREVIOUS=OLD.
#      Redeploy.
#   2. Wait > 24h (full JWT TTL) so all OLD-signed sessions expire.
#   3. Drop JWT_SECRET_PREVIOUS. Redeploy.
JWT_SECRET_PREVIOUS=
AUTH_DOMAIN=localhost:5173
AUTH_RPC_URL=https://api.testnet.abs.xyz
AUTH_CHAIN_ID=11124
